{
	"name": "@drewsepsi/squido-cloud",
	"version": "0.1.0",
	"description": "Squido Cloud client — session sync, auth, and API integration",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@drewsepsi/squido-agent-core": "0.1.0"
	},
	"devDependencies": {
		"shx": "0.4.0",
		"typescript": "5.9.3"
	}
}
